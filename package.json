{
  "name": "@nextcloud/logger",
  "version": "2.5.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -d && babel ./lib --out-dir dist --extensions '.ts,.tsx' --source-maps",
    "build:doc": "typedoc",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "dev": "babel ./lib --out-dir dist --extensions '.ts,.tsx' --watch",
    "test": "jest"
  },
  "keywords": [
    "nextcloud"
  ],
  "homepage": "https://github.com/nextcloud/nextcloud-logger#readme",
  "author": "Christoph Wurst",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/nextcloud/nextcloud-logger"
  },
  "dependencies": {
    "@nextcloud/auth": "^2.0.0",
    "core-js": "^3.6.4"
  },
  "devDependencies": {
    "@babel/cli": "^7.8.4",
    "@babel/core": "^7.8.7",
    "@babel/preset-env": "^7.8.7",
    "@babel/preset-typescript": "^7.8.3",
    "@nextcloud/browserslist-config": "^2.0.0",
    "@nextcloud/eslint-config": "^8.2.1",
    "@nextcloud/typings": "^1.6.0",
    "@types/jest": "^29.2.5",
    "eslint": "^8.33.0",
    "jest": "^29.3.1",
    "jest-environment-jsdom": "^29.3.1",
    "ts-jest": "^29.0.3",
    "typedoc": "^0.23.24",
    "typescript": "^4.9.4"
  },
  "browserslist": [
    "extends @nextcloud/browserslist-config"
  ],
  "eslintConfig": {
    "extends": "@nextcloud",
    "ignorePatterns":["dist/**/*"],
    "overrides": [
      {
        "files": ["tests/**/*"],
        "rules": {
          "@typescript-eslint/no-explicit-any": "off",
          "@typescript-eslint/ban-ts-comment": "off"
        }
      }
    ]
  },
  "engines": {
    "node": "^16.0.0",
    "npm": "^7.0.0 || ^8.0.0"
  }
}
